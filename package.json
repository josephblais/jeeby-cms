{
  "name": "jeeby-cms",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Block-based CMS for Next.js — Firebase, drag-and-drop, draft/publish",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./admin": {
      "import": "./dist/admin.mjs",
      "require": "./dist/admin.js"
    },
    "./server": {
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./dist/styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "dist/styles.css"
  ],
  "scripts": {
    "build": "tsup && cp styles/cms.css dist/styles.css && node -e \"const fs=require('fs'); ['dist/index.mjs','dist/index.js','dist/admin.mjs','dist/admin.js'].forEach(f=>{ const c=fs.readFileSync(f,'utf8'); if(!c.startsWith('\\\"use client\\\"')) fs.writeFileSync(f,'\\\"use client\\\";\\n'+c); })\"",
    "build:watch": "tsup --watch",
    "test": "node --import ./scripts/test-register.js --experimental-test-module-mocks --test 'src/**/*.test.js'"
  },
  "peerDependencies": {
    "dompurify": "^3.0.0",
    "firebase": ">=10",
    "firebase-admin": ">=12",
    "framer-motion": ">=11",
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18",
    "video.js": "^8.23.7"
  },
  "peerDependenciesMeta": {
    "dompurify": {
      "optional": true
    },
    "firebase-admin": {
      "optional": true
    },
    "video.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "dompurify": "^3.3.3",
    "firebase-admin": ">=12",
    "react": ">=18",
    "react-dom": ">=18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
